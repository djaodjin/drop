<?xml version="1.0" ?>
<projects>
  <project name="backstage">
    <title>configuration of the development forum</title>
    <description>
Maintenance scripts for the team communication, build, and source repositories
servers.
    </description>
    <maintainer>
      <personname>Sebastien Mirolo</personname>
      <email>smirolo@djaodjin.com</email>
    </maintainer>
    <variable name="domainName">
      <description>Domain name for the machine being configured.</description>
    </variable>
    <package name="RedHat">
      <fetch>
        <url>https://packages.gitlab.com/install/repositories/gitlab/gitlab-ee/config_file.repo?os=amzn&dist=2023&source=script</url>
        <sha1>6f6428deee881efa18003482d5353587fbf35b5b</sha1>
      </fetch>
      <fetch>
        <url>https://packages.gitlab.com/install/repositories/runner/gitlab-runner/config_file.repo?os=amzn&dist=2023&source=script</url>
        <sha1>6f6428deee881efa18003482d5353587fbf35b5b</sha1>
      </fetch>
      <!-- Access control -->
      <dep name="iptables">
        <bin>iptables</bin>
        <port>22</port>
      </dep>
      <dep name="authconfig">
        <bin>authconfig</bin>
      </dep>
      <dep name="sssd">
        <bin>sssd</bin>
      </dep>
      <dep name="openssh-ldap">
        <libexec>.*/(openssh)/ssh-ldap-helper</libexec>
      </dep>
      <dep name="openldap-clients">
        <bin>ldapsearch</bin>
      </dep>
      <!-- monitoring -->
      <dep name="fail2ban">
        <bin>fail2ban-client</bin>
      </dep>
      <dep name="monit">
        <bin>monit</bin>
      </dep>
      <dep name="otelcol-contrib">
        <bin>otecol-contrib</bin>
      </dep>
      <dep name="rsyslog">
        <bin>rsyslogd</bin>
      </dep>
      <!-- reverse proxy -->
      <dep name="nginx">
        <bin>nginx</bin>
        <extra name="site-config/%(domainName)s.conf">
          <domainName>%(domainName)s</domainName>
          <port>80</port>
          <webapp>
            <path>/</path>
            <port>8040</port>
            <app_name>semilla</app_name>
          </webapp>
          <webapp>
            <app_name>gitlab</app_name>
            <path>/gitlab</path>
            <port>8080</port>
          </webapp>
        </extra>
      </dep>
      <!-- source repositories -->
      <dep name="gitlab-ee">
        <bin>gitlabctl</bin>
      </dep>
      <dep name="gitlab-runner">
        <bin>gitlab-runner</bin>
      </dep>
      <dep name="google-chrome-stable">
        <bin>google-chrome</bin>
      </dep>
      <dep name="postgresql17-server">
        <bin>postgres</bin>
        <listen_addresses>private-ip.local</listen_addresses>
      </dep>
      <dep name="postgresql17-contrib">
        <lib>.*/pg_stat_statements.so</lib>
      </dep>
      <dep name="semilla">
        <bin>semilla</bin>
        <cgi-bin>%(domainName)s</cgi-bin>
        <extra name="/etc/semilla/%(domainName)s.conf"></extra>
      </dep>
      <!-- build bot -->
      <dep name="libselinux-python">
        <!-- to use `lineinfo:` in ansible playbooks -->
        <share>.*/(selinux)/__init__.py</share>
      </dep>
    </package>
  </project>
  <project name="semilla">
    <description>
      CGI for presenting documents, source code and build results
    </description>
    <maintainer>
      <personname>Sebastien Mirolo</personname>
      <email>smirolo@djaodjin.com</email>
    </maintainer>
    <package name="Fedora">
      <fetch>
        <url>https://djaodjin.com/pub/fedora/linux/updates/fc21/x86_64/semilla-0.4-0.x86_64.rpm</url>
        <size>1114016</size>
        <sha1>ad0d14427b46942909eee7e77dad702ab6503851</sha1>
      </fetch>
      <dep name="git-all">
        <bin>git</bin>
      </dep>
      <dep name="cryptopp">
        <lib>cryptopp.so</lib>
      </dep>
      <dep name="boost">
        <lib>boost_date_time.so</lib>
        <lib>boost_filesystem.so</lib>
        <lib>boost_program_options.so</lib>
        <lib>boost_random.so</lib>
        <lib>boost_regex.so</lib>
        <lib>boost_system.so</lib>
      </dep>
      <dep name="poco-net">
        <lib>PocoNet.so</lib>
      </dep>
      <dep name="poco-util">
        <lib>PocoUtil.so</lib>
      </dep>
    </package>
  </project>
</projects>
